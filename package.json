{
  "name": "odinserver",
  "version": "1.0.0",
  "description": "REST API and session authentication service for OdinBook",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "devstart": "npm run dev",
    "db:migrate": "node db/migrate.js",
    "db:seed": "node db/seed.js",
    "check": "find . -path ./node_modules -prune -o -name '*.js' -print0 | xargs -0 -n 1 node --check",
    "test": "npm run check && node --test --test-concurrency=1"
  },
  "keywords": [],
  "author": "Wilson Huang",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.5.1",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-async-handler": "^1.2.0",
    "express-session": "^1.19.0",
    "multer": "^2.2.0",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-local": "^1.0.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
